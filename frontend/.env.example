# Backend API base URL (must end with /api)
#
# iOS Simulator / web on same Mac:
#   EXPO_PUBLIC_API_URL=http://localhost:8000/api
#
# Physical iPhone (same Wi‑Fi as Mac) — replace with your Mac's IP:
#   Run: ipconfig getifaddr en0
#   EXPO_PUBLIC_API_URL=http://192.168.1.XXX:8000/api
#
# After editing, restart Expo: npx expo start
EXPO_PUBLIC_API_URL=http://localhost:8000/api
